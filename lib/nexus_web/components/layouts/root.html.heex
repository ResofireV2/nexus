<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content={@pwa_theme_color} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content={@pwa_status_bar_style} />
    <meta name="apple-mobile-web-app-title" content={@pwa_app_name} />
    <link rel="apple-touch-icon" href={@pwa_icon_path} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={@og_site_name} />
    <%= if @og_description != "" do %>
    <meta property="og:description" content={@og_description} />
    <meta name="description"        content={@og_description} />
    <% end %>
    <%= if @og_image_url do %>
    <meta property="og:image"         content={@og_image_url} />
    <meta property="og:image:width"   content="1200" />
    <meta property="og:image:height"  content="630" />
    <meta name="twitter:card"         content="summary_large_image" />
    <meta name="twitter:image"        content={@og_image_url} />
    <% else %>
    <meta name="twitter:card" content="summary" />
    <% end %>

    <.live_title suffix=" · Nexus">
      <%= assigns[:page_title] || "Forum" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <!-- Preconnect to external origins used on every page load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" />
    <!-- Fancybox loaded on demand — see openFancybox() in nexus.jsx -->
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>
    <%= if @extension_manifests != %{} do %>
    <script>
      // Manifests for every enabled extension, keyed by slug. Each entry is the
      // normalized manifest_version 2 JSON document validated by
      // Nexus.Extensions.ManifestSchema. The extension bundles below read this
      // at register time to verify each registration was declared in the
      // manifest; mismatches are logged to console and surfaced in the admin
      // runtime panel.
      window._nexusExtensionManifests = <%= Phoenix.HTML.raw(Jason.encode!(@extension_manifests, escape: :html_safe)) %>;
      window._nexusExtensionMismatches = {};
    </script>
    <% end %>
    <%= for url <- @extension_bundle_urls do %>
    <script defer type="text/javascript" src={url}></script>
    <% end %>

    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});

        // Respond to the service worker's GET_AUTH_TOKEN message.
        // The pushsubscriptionchange handler in sw.js sends this message
        // to get the current JWT so it can re-register a renewed push
        // subscription without requiring the user to visit Settings.
        navigator.serviceWorker.addEventListener('message', function(event) {
          if (event.data && event.data.type === 'GET_AUTH_TOKEN') {
            var token = localStorage.getItem('nexus_token');
            event.ports[0].postMessage({ token: token });
          }
        });
      }
    </script>
    <script>
      // Apply theme immediately before React loads to prevent flash.
      // This script is intentionally synchronous and placed after app.css
      // but before any deferred scripts so it runs at parse time.
      (function() {
        try {
          var pref   = localStorage.getItem('nexus_theme_pref') || 'auto';
          var cfgRaw = localStorage.getItem('nexus_theme_cfg');
          var cfg    = cfgRaw ? JSON.parse(cfgRaw) : {darkEnabled:true, lightEnabled:true, defaultTheme:'dark'};
          var darkEnabled  = cfg.darkEnabled  !== false;
          var lightEnabled = cfg.lightEnabled !== false;
          var defaultTheme = cfg.defaultTheme || 'dark';
          var osDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;

          // Resolve theme respecting allowed options
          var theme;
          if (pref === 'light' && lightEnabled)       { theme = 'light'; }
          else if (pref === 'dark' && darkEnabled)    { theme = 'dark';  }
          else if (pref === 'light' && !lightEnabled) { theme = darkEnabled ? 'dark' : 'dark'; }
          else if (pref === 'dark'  && !darkEnabled)  { theme = lightEnabled ? 'light' : 'dark'; }
          else {
            // auto or unset: use admin default, else OS, else dark
            if (defaultTheme === 'light' && lightEnabled)    { theme = 'light'; }
            else if (defaultTheme === 'dark' && darkEnabled) { theme = 'dark';  }
            else if (darkEnabled && lightEnabled) { theme = osDark ? 'dark' : 'light'; }
            else if (lightEnabled) { theme = 'light'; }
            else { theme = 'dark'; }
          }

          var r = document.documentElement;

          // Restore cached computed CSS vars from the last successful applyTheme call.
          // These include custom accent colors and tint colors set in the admin panel.
          // Falls back to hardcoded defaults if no cache exists yet (first visit).
          var cachedVars = null;
          try {
            var raw = localStorage.getItem('nexus_appearance_vars');
            if (raw) {
              var parsed = JSON.parse(raw);
              // Only use the cache if it matches the resolved theme —
              // otherwise we'd flash the wrong theme's custom colors.
              if (parsed.theme === theme) cachedVars = parsed;
            }
          } catch(e) {}

          if (cachedVars) {
            // Restore every cached var exactly as it was set by applyTheme
            r.setAttribute('data-theme', theme);
            var skip = ['theme'];
            Object.keys(cachedVars).forEach(function(k) {
              if (skip.indexOf(k) === -1 && cachedVars[k]) {
                r.style.setProperty(k, cachedVars[k]);
              }
            });
          } else if (theme === 'light') {
            r.setAttribute('data-theme', 'light');
            r.style.setProperty('--bg',        '#f5f4fb');
            r.style.setProperty('--s1',        '#ffffff');
            r.style.setProperty('--s2',        '#edeaf9');
            r.style.setProperty('--s3',        '#e3dff5');
            r.style.setProperty('--t1',        '#1a1428');
            r.style.setProperty('--t2',        'rgba(26,20,80,0.70)');
            r.style.setProperty('--t3',        'rgba(26,20,80,0.50)');
            r.style.setProperty('--t4',        'rgba(26,20,80,0.30)');
            r.style.setProperty('--t5',        'rgba(26,20,80,0.18)');
            r.style.setProperty('--b1',        'rgba(26,20,80,0.07)');
            r.style.setProperty('--b2',        'rgba(26,20,80,0.10)');
            r.style.setProperty('--b3',        'rgba(26,20,80,0.14)');
            r.style.setProperty('--ac',        '#7351db');
            r.style.setProperty('--ac-bg',     'rgba(115,81,219,0.09)');
            r.style.setProperty('--ac-border', 'rgba(115,81,219,0.25)');
            r.style.setProperty('--ac-text',   '#5b3db5');
            r.style.setProperty('--ac-on',     '#ffffff');
          } else {
            r.setAttribute('data-theme', 'dark');
            r.style.setProperty('--bg',        '#0d0d14');
            r.style.setProperty('--s1',        '#13121e');
            r.style.setProperty('--s2',        '#18182a');
            r.style.setProperty('--s3',        '#1e1c2e');
            r.style.setProperty('--t1',        '#f0eeff');
            r.style.setProperty('--t2',        'rgba(255,255,255,0.65)');
            r.style.setProperty('--t3',        'rgba(255,255,255,0.45)');
            r.style.setProperty('--t4',        'rgba(255,255,255,0.25)');
            r.style.setProperty('--t5',        'rgba(255,255,255,0.15)');
            r.style.setProperty('--b1',        'rgba(255,255,255,0.07)');
            r.style.setProperty('--b2',        'rgba(255,255,255,0.10)');
            r.style.setProperty('--b3',        'rgba(255,255,255,0.14)');
            r.style.setProperty('--ac',        '#a78bfa');
            r.style.setProperty('--ac-on',     '#0d0d14');
            r.style.setProperty('--ac-bg',     'rgba(167,139,250,0.09)');
            r.style.setProperty('--ac-border', 'rgba(167,139,250,0.25)');
            r.style.setProperty('--ac-text',   '#c4b5fd');
          }

          // Restore non-color appearance settings (font sizes, avatar radius, custom CSS)
          try {
            var appRaw = localStorage.getItem('nexus_appearance_app');
            if (appRaw) {
              var app = JSON.parse(appRaw);
              if (app.avatar_radius != null) r.style.setProperty('--av-radius', app.avatar_radius + '%');
              if (app.fs_ui)      r.style.setProperty('--fs-ui',      app.fs_ui + 'px');
              if (app.fs_body)    r.style.setProperty('--fs-body',    app.fs_body + 'px');
              if (app.fs_title)   r.style.setProperty('--fs-title',   app.fs_title + 'px');
              if (app.fs_content) r.style.setProperty('--fs-content', app.fs_content + 'px');
              if (app.fs_code)    r.style.setProperty('--fs-code',    app.fs_code + 'px');
              if (app.custom_css) {
                var style = document.createElement('style');
                // Strip CSS constructs that can exfiltrate data:
                // @import, external url(), and CSS expressions.
                var safe = app.custom_css
                  .replace(/@import\b[^;]*(;|$)/gi, '')
                  .replace(/url\s*\(\s*(?!['"]?(data:|\/|#))[^)]+\)/gi, '')
                  .replace(/expression\s*\(/gi, '');
                style.textContent = safe;
                document.head.appendChild(style);
              }
            }
          } catch(e) {}

        } catch(e) {}
      })();
    </script>
  </head>
  <body style="background:#0d0d14;color:#f0eeff;">
    <%= @inner_content %>
  </body>
</html>
