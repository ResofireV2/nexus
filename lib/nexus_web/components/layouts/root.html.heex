<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content={@pwa_theme_color} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content={@pwa_status_bar_style} />
    <meta name="apple-mobile-web-app-title" content={@pwa_app_name} />
    <link rel="apple-touch-icon" href={@pwa_icon_path} />

    <!-- Favicon (server-rendered so it never flashes the default icon) -->
    <%= if @branding_favicon_url do %>
    <link rel="icon" href={@branding_favicon_url} />
    <% end %>

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={@og_site_name} />
    <%= if @og_description != "" do %>
    <meta property="og:description" content={@og_description} />
    <meta name="description"        content={@og_description} />
    <% end %>
    <%= if @og_image_url do %>
    <meta property="og:image"         content={@og_image_url} />
    <meta property="og:image:width"   content="1200" />
    <meta property="og:image:height"  content="630" />
    <meta name="twitter:card"         content="summary_large_image" />
    <meta name="twitter:image"        content={@og_image_url} />
    <% else %>
    <meta name="twitter:card" content="summary" />
    <% end %>

    <.live_title suffix=" · Nexus">
      <%= assigns[:page_title] || "Forum" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />

    <!-- Server-computed theme variables. Rendered before any script so the very
         first paint has the correct accent, surfaces and text colours for both
         modes with no round-trip. The bare :root rule is the admin default
         (used pre-JS / no-JS); the [data-theme] rules take over the instant the
         inline script below sets data-theme. Values are computed by
         Nexus.Appearance.ThemeVars and match applyTheme() in nexus.jsx exactly,
         so no re-paint occurs when /branding later resolves. -->
    <style id="nexus-theme-vars"><%= Phoenix.HTML.raw(@theme_vars_css) %></style>

    <!-- Preconnect to external origins used on every page load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" />

    <!-- Start fetching the logo during HTML parse so it is painted with the
         first render instead of after React mounts. -->
    <%= if @branding_logo_url do %>
    <link rel="preload" as="image" href={@branding_logo_url} />
    <% end %>

    <!-- Fancybox loaded on demand — see openFancybox() in nexus.jsx -->
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>

    <script>
      // Server-injected branding + theme config. Read synchronously by the
      // inline theme script below and by nexus.jsx at module load, so the logo,
      // favicon and theme are known on the first render even on a cold cache.
      window.__nexusBranding = <%= Phoenix.HTML.raw(@branding_json) %>;
      window.__nexusThemeCfg = <%= Phoenix.HTML.raw(@theme_cfg_json) %>;
    </script>

    <%= if @extension_manifests != %{} do %>
    <script>
      // Manifests for every enabled extension, keyed by slug. Each entry is the
      // normalized manifest_version 2 JSON document validated by
      // Nexus.Extensions.ManifestSchema. The extension bundles below read this
      // at register time to verify each registration was declared in the
      // manifest; mismatches are logged to console and surfaced in the admin
      // runtime panel.
      window._nexusExtensionManifests = <%= Phoenix.HTML.raw(Jason.encode!(@extension_manifests, escape: :html_safe)) %>;
      window._nexusExtensionMismatches = {};
    </script>
    <% end %>
    <%= for url <- @extension_bundle_urls do %>
    <script defer type="text/javascript" src={url}></script>
    <% end %>

    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});

        // Respond to the service worker's GET_AUTH_TOKEN message.
        // The pushsubscriptionchange handler in sw.js sends this message
        // to get the current JWT so it can re-register a renewed push
        // subscription without requiring the user to visit Settings.
        navigator.serviceWorker.addEventListener('message', function(event) {
          if (event.data && event.data.type === 'GET_AUTH_TOKEN') {
            var token = localStorage.getItem('nexus_token');
            event.ports[0].postMessage({ token: token });
          }
        });
      }
    </script>
    <script>
      // Resolve which theme to show and set data-theme BEFORE first paint.
      // All colour variables for both themes are already in the server-rendered
      // <style id="nexus-theme-vars"> block above, so this script no longer sets
      // any colours itself — it only picks the mode. That removes the old
      // localStorage-cache race that caused the accent colour to flash on a cold
      // cache. The user's stored preference still wins; the allowed-theme config
      // comes from the server (window.__nexusThemeCfg).
      (function() {
        try {
          var cfg = window.__nexusThemeCfg || {darkEnabled:true, lightEnabled:true, defaultTheme:'dark'};
          var darkEnabled  = cfg.darkEnabled  !== false;
          var lightEnabled = cfg.lightEnabled !== false;
          var defaultTheme = cfg.defaultTheme || 'dark';

          var pref = 'auto';
          try { pref = localStorage.getItem('nexus_theme_pref') || 'auto'; } catch(e) {}
          var osDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;

          var theme;
          if (pref === 'light' && lightEnabled)      { theme = 'light'; }
          else if (pref === 'dark' && darkEnabled)   { theme = 'dark';  }
          else if (pref === 'light' && !lightEnabled){ theme = 'dark';  }
          else if (pref === 'dark'  && !darkEnabled) { theme = lightEnabled ? 'light' : 'dark'; }
          else {
            if (defaultTheme === 'light' && lightEnabled)    { theme = 'light'; }
            else if (defaultTheme === 'dark' && darkEnabled) { theme = 'dark';  }
            else if (darkEnabled && lightEnabled) { theme = osDark ? 'dark' : 'light'; }
            else if (lightEnabled) { theme = 'light'; }
            else { theme = 'dark'; }
          }

          document.documentElement.setAttribute('data-theme', theme);

          // Restore admin custom CSS synchronously (independent of the theme
          // variables above). Kept here so custom rules apply before first paint.
          var appRaw = localStorage.getItem('nexus_appearance_app');
          if (appRaw) {
            var app = JSON.parse(appRaw);
            if (app.custom_css) {
              var style = document.createElement('style');
              // Strip CSS constructs that can exfiltrate data:
              // @import, external url(), and CSS expressions.
              var safe = app.custom_css
                .replace(/@import\b[^;]*(;|$)/gi, '')
                .replace(/url\s*\(\s*(?!['"]?(data:|\/|#))[^)]+\)/gi, '')
                .replace(/expression\s*\(/gi, '');
              style.textContent = safe;
              document.head.appendChild(style);
            }
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body style="background:var(--bg);color:var(--t1);">
    <%= @inner_content %>
  </body>
</html>
