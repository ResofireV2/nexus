+  @doc """
+  Recomputes every space's post_count from the posts table.
+
+  The counters are maintained incrementally; this exists to repair drift and is
+  run once by the recount migration. Counts visible posts only, matching what
+  the feed actually shows.
+  """
+  def recount_space_post_counts do
+    Repo.query!("""
+    UPDATE spaces s
+    SET post_count = COALESCE(
+      (SELECT COUNT(*) FROM posts p WHERE p.space_id = s.id AND p.hidden = false), 0)
+    """)
+
+    :ok
+  end
+
+  @doc "Recomputes every tag's post_count from the post_tags join table."
+  def recount_tag_post_counts do
+    Repo.query!("""
+    UPDATE tags t
+    SET post_count = COALESCE((
+      SELECT COUNT(*)
+      FROM post_tags pt
+      JOIN posts p ON p.id = pt.post_id
+      WHERE pt.tag_id = t.id AND p.hidden = false
+    ), 0)
+    """)
+
+    :ok
+  end
