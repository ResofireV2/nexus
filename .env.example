# Copy this to .env and fill in the three secrets before deploying

PHX_HOST=billyrayfoss.com

# Generate with: openssl rand -base64 48
SECRET_KEY_BASE=REPLACE_WITH_GENERATED_SECRET

# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# Generate with: openssl rand -base64 24
DB_PASSWORD=REPLACE_WITH_GENERATED_SECRET

# Optional: uncomment one for real email delivery
# POSTMARK_API_KEY=your_key
# RESEND_API_KEY=your_key
